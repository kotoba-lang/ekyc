{:paths ["src"]
 :deps {kotoba-lang/identity      {:local/root "../identity"}
        io.github.kotoba-lang/html {:local/root "../html"}
        io.github.kotoba-lang/css  {:local/root "../css"}}
 :aliases
 {:test {:extra-paths ["test"]
         ;; datascript/datascript is the real portable datascript.core
         ;; library (same .cljc source that also compiles to run in a
         ;; browser) -- test-only, so it does not become a runtime dep of
         ;; kotoba.ekyc.jurisdiction-graph itself (that namespace only
         ;; emits EDN; ANY Datalog engine, real Datomic included, can
         ;; consume it). Mirrors orgs/etzhayyim/global-energy-datoms'
         ;; deps.edn, this workspace's precedent for proving DataScript
         ;; compatibility via the JVM artifact.
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                      datascript/datascript {:mvn/version "1.7.8"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
